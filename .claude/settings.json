{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add:*)"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Read(*.env)",
      "Bash(rm:*)",
      "Bash(curl:*)",
      "Edit"
    ],
    "defaultMode": "default"
  }
}
